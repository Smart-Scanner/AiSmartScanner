# Google OAuth credentials
# Create at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must match the deployed app, e.g. http://localhost:5050/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Flask session signing key — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=

# Admins are stored in auth.db (users.is_admin), not env. Bootstrap with:
#   python scripts/add_admin.py <email>

# fingerprint.com Pro — sign up at https://dashboard.fingerprint.com/signup
# Region: us | eu | ap   (api host derived: api.fpjs.io | eu.api.fpjs.io | ap.api.fpjs.io)
FINGERPRINT_PUBLIC_KEY=
FINGERPRINT_SECRET_KEY=
FINGERPRINT_API_REGION=us
